PORT=3000
JWT_SECRET=change_this_to_a_long_random_secret

# Production: set NODE_ENV=production on your host (Render, etc.)
# NODE_ENV=production

# Optional: GitHub Pages origin(s) for CORS if the browser calls this API from another site.
# Comma-separated list. Example:
# CLIENT_ORIGIN=https://sreekrishna2023.github.io
# CLIENT_ORIGINS=https://sreekrishna2023.github.io,https://www.yourdomain.com

# Choose one: openai | gemini | anthropic
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional listing/data/search connectors
RENTCAST_API_KEY=
SERPAPI_API_KEY=
